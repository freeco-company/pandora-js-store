# Required — set these in CI secrets for production builds
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_STORAGE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Shared secret for POST /api/revalidate. Laravel backend uses this to
# bust Next.js fetch caches when admin-editable content changes
# (banners, campaigns, etc). Must match REVALIDATE_SECRET in backend/.env.
REVALIDATE_SECRET=
