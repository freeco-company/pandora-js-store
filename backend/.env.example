APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Gmail SMTP (free 500/day). App Password required (2FA must be on).
# Get one at: https://myaccount.google.com/apppasswords
# Local dev: leave MAIL_MAILER=log so mails dump to storage/logs/laravel.log.
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@pandora.js-store.com.tw"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FRONTEND_URL=http://localhost:3000

# Shared secret for POST /api/revalidate on the Next.js frontend.
# Must match REVALIDATE_SECRET in frontend/.env.
REVALIDATE_SECRET=

# Cloudflare API (used to purge HTML when admin content changes).
# Token scope: Zone.Cache Purge. Leave blank on local dev.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

VITE_APP_NAME="${APP_NAME}"
ECPAY_SENDER_NAME=
ECPAY_SENDER_CELLPHONE=
ECPAY_LOGISTICS_AUTO=false

# ─── Pandora Core Identity Service (ADR-001) ────────────────────
# dev 預設 false；staging / prod 等 platform skeleton 部署完才 enable
IDENTITY_MIRROR_ENABLED=false
PANDORA_CORE_BASE_URL=
PANDORA_CORE_INTERNAL_SECRET=

# Phase 2 (ADR-007 / pandora-js-store#11) — webhook receiver
# 與 platform 端 IDENTITY_CONSUMER_PANDORA_JS_STORE_SECRET 必須一致
PANDORA_CORE_WEBHOOK_SECRET=
PANDORA_CORE_WEBHOOK_WINDOW_SECONDS=300

# Phase 3 (ADR-007 / pandora-js-store#12) — OAuth cutover
# legacy   = 完全不打 platform（預設、prod 安全值）
# shadow   = 主寫本地、副寫 platform，用 log 比對 uuid 對齊度（驗證階段）
# cutover  = platform 是 source of truth；可加 whitelist 限定 canary 用戶
IDENTITY_CUTOVER_MODE=legacy
# canary 階段限定 emails（CSV）；空 = 全開
IDENTITY_CUTOVER_WHITELIST=
# cutover 模式下 platform 失敗時是否 fallback 到 legacy（推薦 true，對客戶無感）
IDENTITY_CUTOVER_FAIL_OPEN=true

# ─── Franchise Webhook → 朵朵 (pandora-meal) ────────────────────
# 母艦標記用戶為加盟夥伴 → 自動送 webhook 給朵朵 unlock FP-gated content
# 朵朵端 receiver 已 prod live (PR #96)，等母艦這邊 secret 設好就會生效。
# secret 必須跟朵朵端 MOTHERSHIP_FRANCHISE_WEBHOOK_SECRET 完全一致。
FRANCHISE_WEBHOOK_URL=https://meal-api.js-store.com.tw/api/internal/franchisee/webhook
MOTHERSHIP_FRANCHISE_WEBHOOK_SECRET=
FRANCHISE_WEBHOOK_TIMEOUT=10
FRANCHISE_WEBHOOK_MAX_ATTEMPTS=5

# ─── Discord Webhooks ───────────────────────────────────────────
DISCORD_COMPLIANCE_WEBHOOK=
DISCORD_ORDERS_WEBHOOK=
DISCORD_ADS_WEBHOOK=

# ─── Google Ads API (read-only) ─────────────────────────────────
# Developer token: https://ads.google.com/aw/apicenter (inside MCC)
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth credentials from Google Cloud Console (type: Web application)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# Refresh token from OAuth Playground (scope: auth/adwords)
GOOGLE_ADS_REFRESH_TOKEN=
# Paid advertising account (10-digit, no dashes)
GOOGLE_ADS_CUSTOMER_ID=
# MCC manager account that owns it (10-digit, no dashes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

DISCORD_ADS_STRATEGY_WEBHOOK=

# ─── LINE Login + Messaging API ─────────────────────────────────
# Login channel — used for Socialite OAuth (member sign-in).
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=https://pandora.js-store.com.tw/api/auth/line/callback
# Messaging API channel — must be in the SAME Provider as the Login channel
# above, otherwise the userId from Login won't match push targets.
# Without these, LINE pushes (order confirms, review reminders, COD asks)
# silently fail.
LINE_MESSAGING_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=
# OA basic id (e.g. @123abcd) — rendered as the friend-add URL on
# order-complete so customers can add the OA before binding.
LINE_OA_BASIC_ID=
